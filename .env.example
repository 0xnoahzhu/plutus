# ──────────────────────────────────────────────────────────────────────────────
# plutus environment variables
# Copy to .env for local dev. .env is gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Connection URL used by the server and the migrate subcommand.
DATABASE_URL=postgres://plutus:plutus@127.0.0.1:5432/plutus

# Postgres credentials consumed by the compose stack (must match DATABASE_URL).
POSTGRES_USER=plutus
POSTGRES_PASSWORD=plutus
POSTGRES_DB=plutus

# ── Server ────────────────────────────────────────────────────────────────────
# Bind address. Default 127.0.0.1 keeps the API local-only.
# Set to 0.0.0.0:8080 when running inside the compose stack.
PLUTUS_BIND_ADDR=127.0.0.1:8080

# When false (default), API endpoints accept anonymous requests. Flip to true
# to require a session cookie or bearer token on every /api/v1/* request.
PLUTUS_API_REQUIRE_AUTH=false

# Master password in plaintext. Single-user, local-only deployment — the
# server compares the value verbatim against this on /auth/login. Leave
# blank to disable cookie login entirely.
PLUTUS_MASTER_PASSWORD=

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info,plutus=debug,tower_http=debug
